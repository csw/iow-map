#!/bin/sh
# Rebuild index.html and confirm it matches what's about to be committed.
# index.html is generated (see CLAUDE.md); this catches an edit to
# tools/app_template.html or tools/corrections.py that wasn't followed by a rebuild.
set -e
cd "$(git rev-parse --show-toplevel)"

before=$(git hash-object index.html)
uv run python tools/build.py --skip-extract >/dev/null
after=$(git hash-object index.html)

if [ "$before" != "$after" ]; then
    echo "error: index.html was stale and has been regenerated." >&2
    echo "Review the changes, then 'git add index.html' and commit again." >&2
    exit 1
fi
